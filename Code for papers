hbar = 1.0546e-34       # J·s
k_B = 8.617e-5          # eV/K

# ============================================
# FLUX OPERATOR FORMULATION (Eqs. 51-53)
# ============================================
def flux_operator_density(R, t, params):
    """
    Probability density flux through dissociative coordinate R
    Based on Eq. (51): J_R = (1/2m_R)(p_R δ(R-R_c) + δ(R-R_c) p_R)
    
    Simplified: Gaussian approximation for delta function
    """
    # Parameters for wavepacket on dissociative surface
    R_center = params['R_center'](t)  # Time-dependent center
    sigma_R = params['sigma_R'](t)    # Time-dependent width
    p_R = params['momentum'](t)       # Average momentum
    
    # Wavepacket density (Gaussian approximation)
    psi = np.exp(-0.5 * ((R - R_center)/sigma_R)**2) / np.sqrt(2*np.pi*sigma_R**2)
    
    # Current density j = (ħ/m) Im(ψ* ∇ψ)
    # For Gaussian: ∇ψ = -((R-R_center)/sigma_R^2) ψ
    grad_psi = -((R - R_center)/sigma_R**2) * psi
    
    # Current density
    j_R = (hbar/mu_R) * (psi * grad_psi).imag  # Should be real for our case
    
    # Gaussian approximation of delta(R-R_c)
    delta_width = 0.002  # nm, small width for delta approximation
    delta_func = np.exp(-0.5*((R - Rc)/delta_width)**2) / np.sqrt(2*np.pi*delta_width**2)
    
    # Flux through Rc (Eq. 52 integrated over R)
    flux_density = j_R * delta_func
    
    return flux_density

def integrated_flux(t, params):
    """
    Time-dependent flux through cleavage threshold Rc
    Eq. (52): J_R(t) = ∫∫ dq dR ψ* J_R ψ
    """
    # Simplified analytical expression
    # Based on wavepacket center approaching Rc
    
    # Wavepacket parameters
    R_center = params['R_center'](t)
    sigma_R = params['sigma_R'](t)
    v_R = params['velocity'](t)  # Average velocity
    
    # Probability density at Rc
    rho_Rc = np.exp(-0.5 * ((Rc - R_center)/sigma_R)**2) / np.sqrt(2*np.pi*sigma_R**2)
    
    # Flux ∝ velocity × density at Rc
    flux = v_R * rho_Rc
    
    # Normalize to initial conditions
    flux = flux * params['A_norm']
    
    return max(0, flux)  # Flux is positive outward

# ============================================
# SURVIVAL PROBABILITY (Eq. 55)
# ============================================
def survival_probability(t, params):
    """
    Survival probability in bound region Ω_bound
    Eq. (55): S(t) = ∑∫∫_{Ω_bound} |ψ|² dq dR
    
    Simplified: Probability that R < Rc (bound state)
    """
    # Wavepacket center and width
    R_center = params['R_center'](t)
    sigma_R = params['sigma_R'](t)
    
    if R_center > Rc + 3*sigma_R:
        # Mostly dissociated
        return 0.01  # Small residual probability
    
    # Probability that R < Rc (error function of Gaussian)
    # P(R < Rc) = 0.5 * [1 + erf((Rc - R_center)/(√2 σ_R))]
    surv_prob = 0.5 * (1 + erf((Rc - R_center)/(np.sqrt(2)*sigma_R)))
    
    # Multiply by population in reactive state (keto)
    P_keto = params['P_keto'](t)
    
    return surv_prob * P_keto + (1 - P_keto)  # Ground state always bound

# ============================================
# TIME-DEPENDENT PARAMETERS FROM MECHANISM
# ============================================
def get_time_dependent_params():
    """Generate time-dependent parameters for flux and survival calculations"""
    
    def R_center(t):
        """Center of wavepacket along R coordinate"""
        t_ps = t * 1e12  # Convert to ps
        
        if t_ps < 0.1:  # 0-100 fs: Before ESIPT
            return R0
        elif t_ps < 0.2:  # 100-200 fs: ESIPT completes
            # Slight expansion as bond weakens
            return R0 + 0.005 * (t_ps - 0.1)/0.1
        else:  # After ESIPT: dissociation
            # Motion on repulsive potential: R ∝ log(t) for exponential repulsion
            t0 = 0.2  # ps, start of dissociation
            v_drift = 0.03  # nm/ps, drift velocity
            R_max = 0.30  # nm, maximum extension
            
            R_diss = R0 + v_drift * (t_ps - t0) * np.exp(-0.5*(t_ps - t0)/2.0)
            return min(R_diss, R_max)
    
    def sigma_R(t):
        """Width of wavepacket along R"""
        t_ps = t * 1e12
        
        sigma0 = 0.012  # nm, initial width (from harmonic ground state)
        
        if t_ps < 0.1:  # Before ESIPT
            return sigma0
        elif t_ps < 0.5:  # During ESIPT and initial dissociation
            # Broadening as bond weakens
            return sigma0 * (1 + 0.5*(t_ps/0.5))
        else:  # During dissociation
            # Continued broadening on repulsive potential
            return sigma0 * (1 + 1.5*np.sqrt(t_ps/2.0))
    
    def velocity(t):
        """Average velocity along R"""
        t_ps = t * 1e12
        
        if t_ps < 0.1:  # Before ESIPT
            return 0.0
        elif t_ps < 0.2:  # ESIPT: bond weakens but not yet moving
            return 0.001  # nm/ps, small initial velocity
        else:  # Dissociation phase
            # Velocity from repulsive potential: v ∝ exp(-bR) gradient
            t0 = 0.2
            v0 = 0.02  # nm/ps, initial dissociation velocity
            # Velocity decays as wavepacket moves outward
            return v0 * np.exp(-0.3*(t_ps - t0))
    
    def momentum(t):
        """Average momentum along R"""
        v = velocity(t)
        p = mu_R * amu_to_kg * v * 1e9  # kg·m/s (v in nm/ps → m/s)
        return p
    
    def P_keto(t):
        """Population in S₁-keto state (reactive state)"""
        t_ps = t * 1e12
        
        # From population dynamics (Figure 2/4)
        if t_ps < 0.05:  # During 2PA
            return 0.0
        elif t_ps < 0.2:  # ESIPT transfer
            # Rise to maximum then decay
            t_esipt = 0.08  # ps, ESIPT time
            P_max = 0.35    # Maximum keto population
            rise = 1 - np.exp(-t_ps/t_esipt)
            decay = np.exp(-max(0, t_ps-0.1)/tau_diss*1e12)
            return P_max * rise * decay
        else:  # Dissociation phase
            # Exponential decay as bond cleaves
            return 0.35 * np.exp(-(t_ps - 0.1)/2.0)
    
    return {
        'R_center': R_center,
        'sigma_R': sigma_R,
        'velocity': velocity,
        'momentum': momentum,
        'P_keto': P_keto,
        'A_norm': 0.35  # Normalization from max keto population
    }

