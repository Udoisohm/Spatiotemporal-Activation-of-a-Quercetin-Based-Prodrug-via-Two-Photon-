import numpy as np
import matplotlib.pyplot as plt
from scipy.integrate import solve_ivp
from matplotlib.gridspec import GridSpec

# ============================================================
# 1. POPULATION DYNAMICS MODEL (3-LEVEL KINETIC SCHEME)
# ============================================================

# Time grid (fs)
t_min = -100.0
t_max = 2000.0
n_steps = 4000
t_eval = np.linspace(t_min, t_max, n_steps)

# Laser pulse parameters (Gaussian)
t0 = 0.0          # fs, pulse center
sigma = 60.0      # fs, pulse width
W0 = 4e-3         # fs^-1, effective two-photon excitation prefactor

def pulse_envelope(t):
    """Normalized Gaussian pulse envelope (0–1)."""
    return np.exp(-0.5 * ((t - t0) / sigma) ** 2)

def excitation_rate(t):
    """Effective two-photon excitation rate W(t) ∝ I(t)^2."""
    env = pulse_envelope(t)
    return W0 * env**2

# Rate constants (fs^-1), chosen to roughly match the schematic
tau_ESIPT_fs = 80.0       # ESIPT timescale ~80 fs
k_ESIPT = 1.0 / tau_ESIPT_fs   # ~1/80 fs^-1
k_S1_enol_loss = 4e-4     # other S1(enol) decay channels
k_S1_keto_loss = 2e-4     # S1(keto) decay (slower)

def rhs(t, y):
    """ODE system for [P_S0, P_S_enol, P_S_keto]."""
    P_S0, P_S_enol, P_S_keto = y
    W_t = excitation_rate(t)
    dP_S0 = -W_t * P_S0
    dP_S_enol = W_t * P_S0 - (k_ESIPT + k_S1_enol_loss) * P_S_enol
    dP_S_keto = k_ESIPT * P_S_enol - k_S1_keto_loss * P_S_keto
    return [dP_S0, P_S_enol, P_S_keto]

# Initial populations: all in S0
y0 = [1.0, 0.0, 0.0]

sol = solve_ivp(rhs, (t_min, t_max), y0, t_eval=t_eval, rtol=1e-8, atol=1e-10)
t = sol.t  # fs
P_S0 = sol.y[0]
P_S_enol = sol.y[1]
P_S_keto = sol.y[2]
pulse = pulse_envelope(t)

# Convert time to ps for plotting
t_ps = t / 1000.0

# ============================================================
# 2. RATE CONSTANTS FOR BAR CHART (s^-1)
# ============================================================
# Representative values to match the conceptual figure
k_2PA_s = 1e13       # two-photon excitation
k_ESIPT_s = 2e13     # ultrafast ESIPT
k_IC_s = 1e12        # internal conversion / nonradiative
k_cleave_s = 5e11    # bond cleavage
k_rad_s = 2e11       # radiative decay

rate_labels = [r'$k_{\mathrm{2PA}}$', r'$k_{\mathrm{ESIPT}}$', r'$k_{\mathrm{IC}}$',
               r'$k_{\mathrm{cleavage}}$', r'$k_{\mathrm{rad}}$']
rate_values = [k_2PA_s, k_ESIPT_s, k_IC_s, k_cleave_s, k_rad_s]

# ============================================================
# 3. FIGURE LAYOUT USING GRIDSPEC
# ============================================================
fig = plt.figure(figsize=(14, 9))
gs = GridSpec(3, 3, height_ratios=[2.0, 2.0, 1.6], width_ratios=[2.0, 1.2, 0.0], figure=fig)

ax_main = fig.add_subplot(gs[0:2, 0])   # main dynamics
ax_zoom = fig.add_subplot(gs[0:2, 1], sharey=ax_main)  # zoom ESIPT region
ax_bar = fig.add_subplot(gs[2, 0:2])    # rate constants

fig.suptitle('Electronic Population Dynamics of Two-Photon ESIPT-Driven Prodrug Activation',
             fontsize=16, fontweight='bold')

# ------------------ Main panel ------------------
ax_main.plot(t_ps, P_S0, label=r'$P_{S_0}(t)$ (Ground State)', linewidth=2.5, color='blue')
ax_main.plot(t_ps, P_S_enol, label=r'$P_{S_{\mathrm{enol}}}(t)$ (Excited Enol)', linewidth=2.5, color='red')
ax_main.plot(t_ps, P_S_keto, label=r'$P_{S_{\mathrm{keto}}}(t)$ (Excited Keto)', linewidth=2.5, color='orange')

ax_main2 = ax_main.twinx()
ax_main2.plot(t_ps, pulse, linestyle='--', linewidth=2.0, color='green',
              label='Laser Pulse (arb. units)')
ax_main2.set_ylabel('Laser Intensity (arb. units)', fontsize=11, fontweight='bold', color='green')
ax_main2.tick_params(axis='y', labelcolor='green')
ax_main2.set_ylim(0, 1.1)

# Shaded regions
ax_main.axvspan(-0.05, 0.25, color='green', alpha=0.08)   # 2PA
ax_main.axvspan(0.0, 0.2, color='purple', alpha=0.08)     # ESIPT
ax_main.axvspan(0.5, 1.5, color='blue', alpha=0.05)       # cleavage

ax_main.set_xlim(t_ps[0], t_ps[-1])
ax_main.set_ylim(0, 1.05)
ax_main.set_xlabel('Time (ps)', fontsize=12, fontweight='bold')
ax_main.set_ylabel('Population', fontsize=12, fontweight='bold')
ax_main.set_title(r'Electronic Population Dynamics: $S_0 \rightarrow S^{\mathrm{enol}}_1 \rightarrow S^{\mathrm{keto}}_1 \rightarrow$ Cleavage',
                  fontsize=12, fontweight='bold', pad=10)
ax_main.grid(alpha=0.3, linestyle='--')

ax_main.text(0.02, 0.82, '2PA Excitation\n(700–900 nm NIR)', fontsize=9, fontweight='bold',
             color='green', bbox=dict(boxstyle='round', facecolor='white', alpha=0.9))
ax_main.annotate('ESIPT\n$\\tau \\approx 80$ fs',
                 xy=(0.08, 0.45), xycoords=('axes fraction', 'data'),
                 xytext=(0.18, 0.55), textcoords=('axes fraction', 'data'),
                 arrowprops=dict(arrowstyle='->', color='purple', linewidth=1.5),
                 fontsize=9, fontweight='bold', color='purple')
ax_main.annotate('Bond Cleavage\n$\\tau \\approx 2$ ps',
                 xy=(1.0, 0.3), xycoords='data',
                 xytext=(0.9, 0.5), textcoords='axes fraction',
                 arrowprops=dict(arrowstyle='->', color='navy', linewidth=1.5),
                 fontsize=9, fontweight='bold', color='navy')

lines1, labels1 = ax_main.get_legend_handles_labels()
lines2, labels2 = ax_main2.get_legend_handles_labels()
ax_main.legend(lines1 + lines2, labels1 + labels2, loc='upper right', fontsize=9, framealpha=0.95)

# ------------------ Zoom panel ------------------
mask_zoom = (t >= 0.0) & (t <= 300.0)
t_zoom_fs = t[mask_zoom]
t_zoom_ps = t_zoom_fs / 1000.0
P_S0_zoom = P_S0[mask_zoom]
P_S_enol_zoom = P_S_enol[mask_zoom]
P_S_keto_zoom = P_S_keto[mask_zoom]
pulse_zoom = pulse[mask_zoom]

ax_zoom.plot(t_zoom_fs, P_S0_zoom, linewidth=2.0, color='blue')
ax_zoom.plot(t_zoom_fs, P_S_enol_zoom, linewidth=2.0, color='red')
ax_zoom.plot(t_zoom_fs, P_S_keto_zoom, linewidth=2.0, color='orange')

ax_zoom2 = ax_zoom.twinx()
ax_zoom2.plot(t_zoom_fs, pulse_zoom, linestyle='--', linewidth=1.8, color='green')
ax_zoom2.set_ylim(0, 1.1)
ax_zoom2.set_yticks([])

ax_zoom.axvspan(0.0, 160.0, color='purple', alpha=0.08)
ax_zoom.set_xlim(0, 300)
ax_zoom.set_xlabel('Time (fs)', fontsize=11, fontweight='bold')
ax_zoom.set_title('Ultrafast ESIPT Region', fontsize=11, fontweight='bold', pad=8)
ax_zoom.grid(alpha=0.3, linestyle='--')

ax_zoom.annotate('$\\tau_{\\mathrm{ESIPT}} \\approx 80$ fs',
                 xy=(80, 0.55), xytext=(140, 0.85),
                 arrowprops=dict(arrowstyle='->', color='purple', linewidth=1.2),
                 fontsize=9, fontweight='bold', color='purple')

# ------------------ Bar chart ------------------
xpos = np.arange(len(rate_labels))
bar_colors = ['green', 'purple', 'red', 'blue', 'gray']

bars = ax_bar.bar(xpos, rate_values, color=bar_colors, edgecolor='black')
ax_bar.set_yscale('log')
ax_bar.set_xticks(xpos)
ax_bar.set_xticklabels(rate_labels, fontsize=11)
