            fontsize=9, va='bottom', ha='left',
            bbox=dict(boxstyle='round', facecolor='white', alpha=0.9))

fig.text(0.5, 0.02,
         'Dynamics show sequential population transfer: Two-photon excitation (~100 fs) → ESIPT (<100 fs) → '
