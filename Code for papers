import numpy as np
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
import warnings
warnings.filterwarnings('ignore')

# ================= GLOBAL STYLE =================
plt.rcParams['font.weight'] = 'bold'
plt.rcParams['axes.labelweight'] = 'bold'
plt.rcParams['axes.titleweight'] = 'bold'
plt.rcParams['xtick.labelsize'] = 11
plt.rcParams['ytick.labelsize'] = 11

# ============================================
# PARAMETERS STRICTLY FROM MANUSCRIPT TABLE 1
# ============================================
q0 = 0.085           # nm, S₀ enol equilibrium
qk = 0.14            # nm, S₁ keto equilibrium
qb = 0.1125          # nm, ESIPT barrier top
R0 = 0.18            # nm, bond equilibrium
Rd = 0.25            # nm, dissociation position

mu_p = 1.05          # amu
mu_R = 15.0          # amu

De = 0.5             # eV
Vb = 0.3             # eV
DeltaE_ke = 0.115    # eV
D_R = 2.5            # eV
D_R_e = 2.0          # eV
D_R_k = 0.8          # eV

a_q = 20.0           # nm^-1
a_R = 15.0           # nm^-1
a_R_k = 10.0         # nm^-1

tau_ESIPT = 80.0     # fs
tau_pulse = 100.0    # fs
tau_diss = 2000.0    # fs

hbar = 0.6582        # eV fs

# ============================================
# 1D POTENTIALS ALONG q AND R
# ============================================
def V0_q(q):
    return De * (1 - np.exp(-a_q * (q - q0)))**2

def V0_R(R):
    return D_R * (1 - np.exp(-a_R * (R - R0)))**2

def Ve_q(q):
    q_term = Vb - 0.5 * 2496.8 * (q - qb)**2
    well_enol = 0.15 * 2496.8 * (q - q0)**2
    well_keto = 0.15 * 2496.8 * (q - qk)**2
    return np.minimum(q_term + well_enol, q_term + well_keto)

def Vk_q(q):
    return DeltaE_ke + 0.5 * 2184.7 * (q - qk)**2

def Vk_R(R):
    return D_R_k * (1 - np.exp(-a_R_k * (R - Rd)))**2

def Vk_R_repulsive(R):
    A = 5.0  # eV
    b = 20.0 # nm^-1
    return A * np.exp(-b * (R - R0))

# ============================================
# WAVEFUNCTION PROJECTIONS (MODELLED GAUSSIANS)
# ============================================
def wavefunction_q(t_fs, q_grid):
    sigma_q0 = 0.008
    psi0 = np.exp(-0.5 * ((q_grid - q0)/sigma_q0)**2)
    psi0 /= np.sqrt(np.sum(np.abs(psi0)**2))

    if t_fs == 0:
        return np.abs(psi0)**2

    if t_fs == 50:
        sigma_q = sigma_q0 * 1.2
        psi = np.exp(-0.5 * ((q_grid - q0)/sigma_q)**2)
        psi /= np.sqrt(np.sum(np.abs(psi)**2))
        return np.abs(psi)**2

    if t_fs == 100:
        sigma_q = sigma_q0 * 1.5
        psi = np.exp(-0.5 * ((q_grid - qk)/sigma_q)**2)
        psi /= np.sqrt(np.sum(np.abs(psi)**2))
        return np.abs(psi)**2

    if t_fs == 1000:
        sigma_q = sigma_q0 * 2.0
        qc = 0.5*(q0 + qk)
        psi = np.exp(-0.5 * ((q_grid - qc)/sigma_q)**2)
        psi /= np.sqrt(np.sum(np.abs(psi)**2))
        return np.abs(psi)**2

    return np.zeros_like(q_grid)

def wavefunction_R(t_fs, R_grid):
    sigma_R0 = 0.012
    psi0 = np.exp(-0.5 * ((R_grid - R0)/sigma_R0)**2)
    psi0 /= np.sqrt(np.sum(np.abs(psi0)**2))

    if t_fs == 0:
        return np.abs(psi0)**2

    if t_fs == 50:
        sigma_R = sigma_R0 * 1.1
        psi = np.exp(-0.5 * ((R_grid - R0)/sigma_R)**2)
        psi /= np.sqrt(np.sum(np.abs(psi)**2))
        return np.abs(psi)**2

    if t_fs == 100:
        sigma_R = sigma_R0 * 1.8
        psi = np.exp(-0.5 * ((R_grid - R0)/sigma_R)**2)
        psi /= np.sqrt(np.sum(np.abs(psi)**2))
        return np.abs(psi)**2

    if t_fs == 1000:
        sigma_R = sigma_R0 * 3.0
        Rc = R0 + 0.05
        psi = np.exp(-0.5 * ((R_grid - Rc)/sigma_R)**2)
