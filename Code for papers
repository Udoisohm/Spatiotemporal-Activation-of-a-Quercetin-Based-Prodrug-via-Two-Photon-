#Codes for Figure 7
import numpy as np
import matplotlib.pyplot as plt

# ===============================
# 1. BASELINE FLUX MODEL (FROM MANUSCRIPT)
# ===============================
R0   = 0.18          # nm, equilibrium bond length
Rc   = 0.22          # nm, cleavage threshold
Rmax = 0.30          # nm, maximum extension

# Time constants (H isotope)
tau_ESIPT_fs = 80.0      # fs
tau_diss_fs  = 2000.0    # fs  (2 ps)
tau_nr_fs    = 1000.0    # fs  (1 ps)

tau_ESIPT_H = tau_ESIPT_fs * 1e-15
tau_diss    = tau_diss_fs  * 1e-15
tau_nr      = tau_nr_fs    * 1e-15

sigma_R0 = 0.012          # nm, initial width

# Time grid 0–5 ps
t_ps = np.linspace(0.0, 5.0, 1500)
t_s  = t_ps * 1e-12

def R_center(t_ps):
    """Wavepacket center along R (same as in flux/KIE figures)."""
    if t_ps < 0.2:
        return R0 + 0.01 * (t_ps / 0.2)
    v_drift = 0.04
    R = R0 + 0.01 + v_drift * (t_ps - 0.2) * np.exp(-(t_ps - 0.2)/2.0)
    return min(R, Rmax)

def sigma_R(t_ps):
    """Wavepacket width along R."""
    if t_ps < 0.2:
        return sigma_R0
    return sigma_R0 * (1.0 + 1.5 * np.sqrt((t_ps - 0.2)/2.0))

def v_R(t_ps):
    """Average radial velocity along R (nm/ps)."""
    if t_ps < 0.2:
        return 0.0
    v0 = 0.06
    return v0 * np.exp(-(t_ps - 0.2)/2.0)

def rho_at_Rc(t_ps):
    """Gaussian probability density at R = Rc."""
    Rc_t = R_center(t_ps)
    sR   = sigma_R(t_ps)
    norm = 1.0 / (np.sqrt(2*np.pi) * sR)
    return norm * np.exp(-0.5 * ((Rc - Rc_t)/sR)**2)

def P_keto(t_s, tau_ESIPT):
    """
    ESIPT-driven keto population:
      S0 --2PA--> S1^enol --(k_ESIPT)--> S1^keto --(k_diss,k_nr)--> products
    """
    t_fs = t_s * 1e15
    P_max  = 0.35
    k_ES   = 1.0 / tau_ESIPT
    k_loss = 1.0 / tau_diss + 1.0 / tau_nr
    P = P_max * (1.0 - np.exp(-k_ES * t_s)) * np.exp(-k_loss * t_s)
    P[t_fs < 50.0] = 0.0        # no keto before 2PA completes
    return P

P_keto_H = P_keto(t_s, tau_ESIPT_H)

def flux_JR(P_keto_vec):
    """Flux through Rc: J_R(t) ∝ v_R · ρ(Rc,t) · P_keto(t)."""
    JR = np.zeros_like(t_ps)
    for i, tp in enumerate(t_ps):
        JR[i] = v_R(tp) * rho_at_Rc(tp) * P_keto_vec[i]
    # Normalise so ∫ J_R dt ≈ 0.35 (baseline quantum yield)
    integral_raw = np.trapz(JR, t_s)
    scale = 0.35 / integral_raw if integral_raw > 0 else 1.0
    return JR * scale

J_ref = flux_JR(P_keto_H)
Y_ref = np.trapz(J_ref, t_s)    # ≈ 0.35
print(f"Baseline activation yield at reference excitation: Y_ref = {Y_ref:.3f}")

# ===============================
# 2. TWO-PHOTON EXCITATION FACTORS
# ===============================
def Phi_2PA_field(E0, E_sat=0.35):
    """
    Two-photon excitation probability vs peak field:
      P_2PA ∝ E0^4 with saturation → x/(1 + x), x = (E0/E_sat)^4
    """
    x = (E0 / E_sat)**4
    return x / (1.0 + x)

def Phi_2PA_lambda(lambda_nm):
    """
    Two-photon excitation vs spectral detuning:
      P_2PA(Δ) ∝ 1 / (Δ^2 + Γ^2)^2
      where Δ = 2ħω - ΔE_2PA  (implemented via energies in eV).
    """
    Egap_2PA = 3.10          # eV, effective two-photon gap
    hc = 1240.0              # eV·nm
    E2 = 2.0 * hc / lambda_nm
    Delta = E2 - Egap_2PA
    Gamma = 0.05             # eV
    return 1.0 / ((Delta**2 + Gamma**2)**2)

# Scan ranges
E0_vals = np.linspace(0.05, 0.70, 80)      # V nm^{-1}
lambda_res = 2.0 * 1240.0 / 3.10           # ≈ 800 nm
lambda_vals = np.linspace(lambda_res - 80, lambda_res + 80, 120)

# Normalised 2PA factors
Phi_E      = Phi_2PA_field(E0_vals)
Phi_E     /= Phi_E.max()
Phi_lambda = Phi_2PA_lambda(lambda_vals)
Phi_lambda /= Phi_lambda.max()

# Final activation yields:
Y_E      = Y_ref * Phi_E
Y_lambda = Y_ref * Phi_lambda

# ===============================
# 3. MAKE THE FIGURE (IN-HOUSE STYLE)
# ===============================
plt.rcParams.update({
    'axes.grid': False,
    'lines.linewidth': 3.0,
    'font.family': 'sans-serif',
    'font.sans-serif': ['Arial', 'DejaVu Sans'],
    'axes.labelweight': 'bold',
    'axes.titlesize': 14,
    'axes.titleweight': 'bold',
    'axes.linewidth': 1.5
})

fig, axes = plt.subplots(1, 2, figsize=(12, 5))

# (a) Yield vs peak field
ax = axes[0]
ax.plot(E0_vals, Y_E, color='blue')
ax.set_xlabel(r'Peak Field $E_0$ (V nm$^{-1}$)', fontsize=12, fontweight='bold')
ax.set_ylabel(r'Final Cleavage Yield $\Phi_{\mathrm{act}}$', fontsize=12, fontweight='bold')
ax.set_title('(a) Yield vs Peak Two-Photon Field', fontsize=14, fontweight='bold')
ax.set_ylim(0, 0.40)

# (b) Yield vs two-photon detuning
ax2 = axes[1]
ax2.plot(lambda_vals, Y_lambda, color='red')
ax2.set_xlabel(r'Central Wavelength $\lambda$ (nm)', fontsize=12, fontweight='bold')
ax2.set_ylabel(r'Final Cleavage Yield $\Phi_{\mathrm{act}}$', fontsize=12, fontweight='bold')
ax2.set_title('(b) Yield vs Two-Photon Detuning', fontsize=14, fontweight='bold')
ax2.set_xlim(lambda_vals.min(), lambda_vals.max())
ax2.set_ylim(0, 0.40)

fig.suptitle('Figure 7. Tunability of ESIPT-Driven Prodrug Activation\n'
             'via Two-Photon Field Strength and Spectral Detuning',
             fontsize=16, fontweight='bold', y=1.02)

