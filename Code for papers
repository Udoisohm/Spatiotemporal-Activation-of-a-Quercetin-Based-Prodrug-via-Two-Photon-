import numpy as np
import matplotlib.pyplot as plt

# ============================================
# Asymmetric double-well PES consistent with manuscript (Option B)
# ============================================

# Proton-transfer coordinate minima (nm)
q_enol = 0.07   # left minimum (enol-like)
q_keto = 0.11   # right minimum (keto-like)
q_center = (q_enol + q_keto) / 2.0
delta_q = (q_keto - q_enol) / 2.0  # half-separation

# Bond coordinate (nm)
R0 = 0.18   # equilibrium bond length
Rd = 0.25   # approximate cleavage threshold

# Energies (eV) - mid-range realistic values
De_S0   = 0.50   # S0 barrier height
Vb_S1e  = 0.30   # S1-enol barrier height
DeltaE_ke = 0.115  # S1 keto-enol offset

D_R_S0  = 2.50   # S0 Morse depth
D_R_S1e = 2.00   # S1-enol Morse depth
D_R_S1k = 0.80   # S1-keto Morse depth (weakened)

a_R = 12.0       # nm^-1 (Morse width)

# Keto curvature in eV/nm^2 (effective)
k_k_Nm = 350.0
conv_Nm_to_eVnm2 = 6.242  # 1 N/m -> eV/nm^2
k_k = k_k_Nm * conv_Nm_to_eVnm2  # effective curvature in eV/nm^2

# Repulsive tail (barrierless) parameters
A_rep = 3.0   # eV
b_rep = 10.0  # nm^-1

# Nonadiabatic coupling parameters
G0 = 0.05     # eV (peak coupling)
sigma_G = 0.02  # nm (width of coupling region)


# ============================================
# Potential energy definitions
# ============================================

def double_well_asym(q, barrier_height):
    """
    Asymmetric double well with minima at q_enol and q_keto.
    Normalized so that V(q_enol) = V(q_keto) = 0 and V(q_center) = barrier_height.
    """
    num = (q - q_enol)**2 * (q - q_keto)**2
    denom = (q_center - q_enol)**2 * (q_center - q_keto)**2
    return barrier_height * (num / denom)


def morse(R, D, R0, a):
    return D * (1 - np.exp(-a * (R - R0)))**2


def V0(q, R):
    """Ground-state PES S0: double-well in q + strong Morse in R."""
    return double_well_asym(q, De_S0) + morse(R, D_R_S0, R0, a_R)


def Ve(q, R):
    """Excited S1-enol PES."""
    return double_well_asym(q, Vb_S1e) + morse(R, D_R_S1e, R0, a_R)


def Vk(q, R):
    """Excited S1-keto PES."""
    q_term = DeltaE_ke + 0.5 * k_k * (q - q_keto)**2
    R = np.asarray(R)
    V_morse_k = morse(R, D_R_S1k, R0, a_R)
    V_rep = A_rep * np.exp(-b_rep * (R - R0))
    R_term = np.where(R > R0, V_rep, V_morse_k)
    return q_term + R_term


def G_coupling(q):
    """Nonadiabatic coupling localized near barrier (Gaussian)."""
    return G0 * np.exp(-0.5 * ((q - q_center)/sigma_G)**2)


# ============================================
# Grids
# ============================================

q_vals = np.linspace(0.04, 0.20, 600)
R_vals = np.linspace(0.10, 0.35, 600)

# Reference energy: S0 enol minimum
E_ref = V0(q_enol, R0)

# Evaluate along q at R=R0
V0_q = V0(q_vals, R0) - E_ref
Ve_q = Ve(q_vals, R0) - E_ref
Vk_q = Vk(q_vals, R0) - E_ref

G_q = G_coupling(q_vals)
gap_q = Ve_q - Vk_q  # already shifted by same reference

# Evaluate along R
V0_R_enol = V0(q_enol, R_vals) - E_ref
Ve_R_enol = Ve(q_enol, R_vals) - E_ref
Vk_R_keto = Vk(q_keto, R_vals) - E_ref

# Pure repulsive tail (same A_rep, b_rep)
V_rep_R = A_rep * np.exp(-b_rep * (R_vals - R0))


# ============================================
# Plot 6-panel figure
# ============================================

fig, axes = plt.subplots(2, 3, figsize=(18, 10))
fig.suptitle("Cross-Sectional Analysis of ESIPT and Bond Activation Coordinates (Corrected)",
             fontsize=16, fontweight='bold')

# ---------- Panel 1: ESIPT PES cut ----------
ax1 = axes[0, 0]
ax1.plot(q_vals, V0_q, color='blue', linewidth=2.5, label=r'$V_0(q,R_0)$')
ax1.plot(q_vals, Ve_q, color='red', linewidth=2.5, label=r'$V_e(q,R_0)$')
ax1.plot(q_vals, Vk_q, color='orange', linewidth=2.5, label=r'$V_k(q,R_0)$')

ax1.axvline(q_enol, color='navy', linestyle='--', linewidth=1.2, label=r'$q_{\mathrm{enol}}$')
ax1.axvline(q_keto, color='darkorange', linestyle='--', linewidth=1.2, label=r'$q_{\mathrm{keto}}$')
ax1.axvline(q_center, color='gray', linestyle=':', linewidth=1.2, label=r'$q_b$')

ax1.set_title('ESIPT Coordinate at $R=R_0$\nAsymmetric double-well', fontweight='bold')
ax1.set_xlabel(r'$q$ (nm)', fontweight='bold')
ax1.set_ylabel('Energy (eV)', fontweight='bold')
ax1.set_ylim(-0.1, max(Vk_q)*1.05)
ax1.grid(alpha=0.3)
ax1.legend(fontsize=9, loc='upper left')

# ---------- Panel 2: Nonadiabatic coupling ----------
ax2 = axes[0, 1]
ax2.plot(q_vals, G_q, color='green', linewidth=2.5)
ax2.axvline(q_center, color='gray', linestyle='--', linewidth=1.2, label=r'$q_b$')
ax2.fill_between(q_vals, 0, G_q, where=(np.abs(q_vals - q_center) <= 1.5*sigma_G),
                 color='green', alpha=0.2)

ax2.set_title('Nonadiabatic Coupling at $R=R_0$\nGaussian localized near barrier', fontweight='bold')
ax2.set_xlabel(r'$q$ (nm)', fontweight='bold')
ax2.set_ylabel(r'$G_{qe}(q)$ (eV)', fontweight='bold')
ax2.grid(alpha=0.3)
ax2.legend(fontsize=9, loc='upper left')

# ---------- Panel 3: Energy gap ----------
ax3 = axes[0, 2]
ax3.plot(q_vals, gap_q, color='purple', linewidth=2.5)
if np.any(np.sign(gap_q[:-1]) != np.sign(gap_q[1:])):
    idx = np.where(np.sign(gap_q[:-1]) != np.sign(gap_q[1:]))[0][0]
    q_cross = q_vals[idx]
    ax3.axvline(q_cross, color='gray', linestyle='--', linewidth=1.2, label='gap crossing')

ax3.set_title(r'Energy Gap Driving ESIPT: $V_e - V_k$', fontweight='bold')
ax3.set_xlabel(r'$q$ (nm)', fontweight='bold')
ax3.set_ylabel('Energy gap (eV)', fontweight='bold')
ax3.grid(alpha=0.3)
ax3.legend(fontsize=9, loc='upper left')

# ---------- Panel 4: Bond coordinate at q = q_enol ----------
ax4 = axes[1, 0]
ax4.plot(R_vals, V0_R_enol, color='blue', linewidth=2.5, label=r'$V_0(q_{\mathrm{enol}},R)$')
ax4.plot(R_vals, Ve_R_enol, color='red', linewidth=2.5, label=r'$V_e(q_{\mathrm{enol}},R)$')
ax4.axvline(R0, color='gray', linestyle='--', linewidth=1.2, label=r'$R_0$')

ax4.set_title(r'Bond Coordinate at $q=q_{\mathrm{enol}}$ (Strong bond)', fontweight='bold')
ax4.set_xlabel(r'$R$ (nm)', fontweight='bold')
ax4.set_ylabel('Energy (eV)', fontweight='bold')
ax4.set_ylim(-0.1, max(V0_R_enol.max(), Ve_R_enol.max())*1.05)
ax4.grid(alpha=0.3)
ax4.legend(fontsize=9, loc='upper right')

# ---------- Panel 5: Bond coordinate at q = q_keto (weakened bond) ----------
ax5 = axes[1, 1]
ax5.plot(R_vals, Vk_R_keto, color='orange', linewidth=2.5, label=r'$V_k(q_{\mathrm{keto}},R)$')
ax5.axvline(R0, color='gray', linestyle='--', linewidth=1.2, label=r'$R_0$')
ax5.axvline(Rd, color='purple', linestyle='--', linewidth=1.2, label=r'$R_d$')
ax5.fill_between(R_vals, 0, Vk_R_keto, where=(R_vals >= Rd),
                 color='orange', alpha=0.2, label='Cleavage region')

ax5.set_title(r'Bond Coordinate at $q=q_{\mathrm{keto}}$ (Weakened bond)', fontweight='bold')
ax5.set_xlabel(r'$R$ (nm)', fontweight='bold')
ax5.set_ylabel('Energy (eV)', fontweight='bold')
ax5.set_ylim(-0.1, max(Vk_R_keto)*1.05)
ax5.grid(alpha=0.3)
ax5.legend(fontsize=9, loc='upper right')

# ---------- Panel 6: Purely repulsive tail ----------
ax6 = axes[1, 2]
ax6.plot(R_vals, V_rep_R, color='red', linewidth=2.5, label=r'$V_{\mathrm{rep}}(R)$')
ax6.axvline(R0, color='gray', linestyle='--', linewidth=1.2, label=r'$R_0$')

ax6.set_title('Barrierless Dissociation Potential\nRepulsive tail', fontweight='bold')
ax6.set_xlabel(r'$R$ (nm)', fontweight='bold')
ax6.set_ylabel('Energy (eV)', fontweight='bold')
ax6.set_ylim(0, max(V_rep_R)*1.05)
ax6.grid(alpha=0.3)
ax6.legend(fontsize=9, loc='upper right')

plt.tight_layout(rect=[0, 0, 1, 0.96])
plt.savefig("CrossSection_ESIPT_corrected.png", dpi=300, bbox_inches='tight')
plt.savefig("CrossSection_ESIPT_corrected.pdf", dpi=300, bbox_inches='tight')
plt.show()

